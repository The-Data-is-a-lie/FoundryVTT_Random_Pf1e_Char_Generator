[
  {
    "name": "Current Natural Armor HP",
    "type": "feat",
    "img": "icons/svg/book.svg",
    "system": {
      "description": {
        "value": "<p>Adjust this field as your armor HP goes up and down to automatically track your current Natural Armor Value.</p><p></p><p>The lower items (Single Unit Natural Armor HP) and (Max Natural Armor HP) are mostly in place so the formula can flow without error. Set them to max charges and only alter the formula if you need to.</p>",
        "instructions": ""
      },
      "tags": [],
      "actions": [],
      "attackNotes": [],
      "effectNotes": [],
      "uses": {
        "value": 7446,
        "per": "charges",
        "autoDeductChargesCost": "",
        "maxFormula": "(@ac.natural.total+@abilities.con.mod) * (@ac.natural.total)",
        "rechargeFormula": ""
      },
      "changes": [
        {
          "formula": "min(-floor(abs(@resources.maxNaturalArmorHp.value - @resources.currentNaturalArmorHp.value) / @resources.singleUnitNaturalArmorHp.value),0)",
          "operator": "add",
          "priority": 0,
          "target": "ac",
          "type": "untyped",
          "_id": "wvCJOEEV"
        },
        {
          "formula": "-min(-floor(abs(@resources.maxNaturalArmorHp.value - @resources.currentNaturalArmorHp.value) / @resources.singleUnitNaturalArmorHp.value),0)",
          "operator": "add",
          "priority": 0,
          "target": "tac",
          "type": "untyped",
          "_id": "vCZulRG8"
        },
        {
          "formula": "@abilities.con.mod",
          "operator": "add",
          "priority": 0,
          "target": "nac",
          "type": "untyped",
          "_id": "pkqs4dcZ"
        },
        {
          "formula": "@abilities.str.mod",
          "operator": "add",
          "priority": 0,
          "target": "nac",
          "type": "untyped",
          "_id": "9XsLuvSB"
        }
      ],
      "changeFlags": {
        "immuneToMorale": false,
        "loseDexToAC": false,
        "noMediumEncumbrance": false,
        "noHeavyEncumbrance": false,
        "mediumArmorFullSpeed": false,
